FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000

MONGODB_URL=""
MONGODB_DATABASE=""

GENERATION_BACKEND = "OPENAI"
EMBEDDING_BACKEND = "OPENAI"

OPENAI_API_KEY="sk-"
OPENAI_BASE_URL=
COHERE_API_KEY="m8-"

OLLAMA_API_URL="http://172.24.112.1:11434"
OLLAMA_THINK=false

GENERATION_MODEL_ID_LITERAL = ["gpt-4o-mini", "gpt-4o"]
